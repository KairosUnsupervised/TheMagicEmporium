{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"allowJs": true,
		"checkJs": true,

		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"skipLibCheck": true,
		"paths": {
			"@tme/library/*": ["../../packages/library/*"],
			"@tme/shared/*": ["../../packages/shared/*"]
		}
	},
	"include": [
		"node_modules/vite/client.d.ts",
		"**/*",
		"../shared/src/types/foundry.d.ts"
	],
	"exclude": ["storybook-static"]
}
